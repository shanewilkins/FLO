{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FLO IR",
  "type": "object",
  "required": ["process","nodes","edges"],
  "properties": {
    "process": {
      "type": "object",
      "required": ["id","name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "oneOf": [{"type":"integer"},{"type":"string"}] },
        "metadata": {
          "type": "object",
          "properties": {
            "render": { "$ref": "#/definitions/render_intent" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id","kind"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "enum": ["start","task","system_task","queue","wait","decision","end","subprocess","parallel_split","parallel_join"] },
          "name": { "type": "string" },
          "lane": { "type": "string" },
          "location": { "type": "string" },
          "workers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "equipment": {
            "type": "array",
            "items": { "type": "string" }
          },
          "note": { "type": "string" },
          "inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "consumes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "produces": {
            "type": "array",
            "items": { "type": "string" }
          },
          "performed_by": {
            "type": "array",
            "items": { "type": "string" }
          },
          "uses": {
            "type": "array",
            "items": { "type": "string" }
          },
          "metadata": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source","target"],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "target": { "type": "string" },
          "outcome": { "type": "string" },
          "label": { "type": "string" },
          "edge_type": { "type": "string" },
          "handoff": { "type": "boolean" },
          "rework": { "type": "boolean" },
          "metadata": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": false
      }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id","name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["role","team","system"] },
          "metadata": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": false
      }
    }
  },
  "definitions": {
    "render_intent": {
      "type": "object",
      "properties": {
        "defaults": { "$ref": "#/definitions/render_view" },
        "views": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/render_view" }
        }
      },
      "additionalProperties": false
    },
    "render_view": {
      "type": "object",
      "properties": {
        "diagram": {
          "type": "string",
          "enum": ["sppm","spaghetti","topdown"]
        },
        "publication": { "$ref": "#/definitions/publication_config" },
        "layout": { "$ref": "#/definitions/layout_config" },
        "sppm": { "$ref": "#/definitions/sppm_config" },
        "spaghetti": { "$ref": "#/definitions/spaghetti_config" }
      },
      "additionalProperties": false
    },
    "publication_config": {
      "type": "object",
      "properties": {
        "page_format": {
          "type": "string",
          "enum": ["letter","a4","legal","tabloid"]
        },
        "margins": {
          "type": "object",
          "properties": {
            "top": { "type": "integer", "minimum": 0 },
            "right": { "type": "integer", "minimum": 0 },
            "bottom": { "type": "integer", "minimum": 0 },
            "left": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "header": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "footer": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "layout_config": {
      "type": "object",
      "properties": {
        "wrap": {
          "type": "string",
          "enum": ["none","auto","manual"]
        },
        "max_width": { "type": "integer", "minimum": 1 },
        "target_columns": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "sppm_config": {
      "type": "object",
      "properties": {
        "label_density": {
          "type": "string",
          "enum": ["full","compact","teaching"]
        },
        "node_numbering": {
          "type": "string",
          "enum": ["none","visible","hidden"]
        },
        "edge_numbering": {
          "type": "string",
          "enum": ["none","visible","hidden"]
        }
      },
      "additionalProperties": false
    },
    "spaghetti_config": {
      "type": "object",
      "properties": {
        "channel": {
          "type": "string",
          "enum": ["material","people","equipment"]
        },
        "people_mode": {
          "type": "string",
          "enum": ["aggregate","individual"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
